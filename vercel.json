{
  "rewrites": [
    {
      "source": "/reachflow",
      "destination": "https://reachflow-app-eight.vercel.app/"
    },
    {
      "source": "/reachflow/(.*)",
      "destination": "https://reachflow-app-eight.vercel.app/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
